        "ecmaVersion": "latest",
        "extraFileExtensions": [],
        "sourceType": "module",
        "useJSXTextNode": true,
      },
    },
    "name": "isentinel/roblox/type-aware-parser",
  },
  {
    "files": [
      "**/*/*.{,c,m}ts",
