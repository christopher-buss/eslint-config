    ],
    "ignores": [],
    "languageOptions": {
      "parser": "typescript-eslint/parser",
      "parserOptions": {
        "ecmaVersion": "latest",
        "extraFileExtensions": [],
        "program": null,
        "project": false,
        "sourceType": "module",
        "useJSXTextNode": true,
      },
    },
    "name": "isentinel/roblox/parser",
  },
  {
    "files": [
      "**/*/*.{,c,m}ts",
      "**/*/*.{,c,m}tsx",
    ],
    "ignores": [
