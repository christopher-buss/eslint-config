  {
    "name": "isentinel/stylistic/setup",
    "plugins": [
      "antfu",
      "style",
    ],
  },
  {
    "files": [
      "**/*.{,c,m}[jt]s{,x}",
    ],
    "name": "isentinel/stylistic",
    "rules": [
      "-antfu/consistent-list-newline",
      "-antfu/if-newline",
      "-style/no-tabs",
      "antfu/top-level-function",
      "curly ["all"]",
      "style/array-bracket-spacing ["never"]",
      "style/arrow-parens ["as-needed",{"requireForBlockBody":true}]",
      "style/arrow-spacing [{"after":true,"before":true}]",
      "style/block-spacing ["always"]",
      "style/brace-style ["stroustrup",{"allowSingleLine":true}]",
      "style/comma-dangle ["always-multiline"]",
      "style/comma-spacing [{"after":true,"before":false}]",
      "style/comma-style ["last"]",
      "style/computed-property-spacing ["never",{"enforceForClassMembers":true}]",
      "style/dot-location ["property"]",
      "style/eol-last",
      "style/generator-star-spacing [{"after":true,"before":false}]",
      "style/indent ["tab",{"ArrayExpression":1,"CallExpression":{"arguments":1},"flatTernaryExpressions":false,"FunctionDeclaration":{"body":1,"parameters":1,"returnType":1},"FunctionExpression":{"body":1,"parameters":1,"returnType":1},"ignoreComments":false,"ignoredNodes":["TSUnionType","TSIntersectionType"],"ImportDeclaration":1,"MemberExpression":1,"ObjectExpression":1,"offsetTernaryExpressions":true,"outerIIFEBody":1,"SwitchCase":1,"tabLength":4,"VariableDeclarator":1}]",
      "style/indent-binary-ops ["tab"]",
      "style/jsx-closing-bracket-location",
      "style/jsx-closing-tag-location",
      "style/jsx-curly-brace-presence [{"propElementValues":"always"}]",
      "style/jsx-curly-newline",
      "style/jsx-curly-spacing ["never"]",
      "style/jsx-equals-spacing",
      "style/jsx-first-prop-new-line",
      "style/jsx-function-call-newline ["multiline"]",
      "style/jsx-indent-props ["tab"]",
      "style/jsx-max-props-per-line [{"maximum":1,"when":"multiline"}]",
      "style/jsx-one-expression-per-line [{"allow":"single-child"}]",
      "style/jsx-quotes",
      "style/jsx-tag-spacing [{"afterOpening":"never","beforeClosing":"never","beforeSelfClosing":"always","closingSlash":"never"}]",
      "style/jsx-wrap-multilines [{"arrow":"parens-new-line","assignment":"parens-new-line","condition":"parens-new-line","declaration":"parens-new-line","logical":"parens-new-line","prop":"parens-new-line","propertyValue":"parens-new-line","return":"parens-new-line"}]",
      "style/key-spacing [{"afterColon":true,"beforeColon":false}]",
      "style/keyword-spacing [{"after":true,"before":true}]",
      "style/lines-between-class-members [{"enforce":[{"blankLine":"always","next":"method","prev":"method"}]}]",
      "style/max-statements-per-line [{"max":1}]",
      "style/member-delimiter-style [{"multiline":{"delimiter":"semi","requireLast":true},"multilineDetection":"brackets","overrides":{"interface":{"multiline":{"delimiter":"semi","requireLast":true}}},"singleline":{"delimiter":"semi"}}]",
      "style/multiline-ternary ["always-multiline"]",
      "style/new-parens",
      "style/no-extra-parens ["functions"]",
      "style/no-floating-decimal",
      "style/no-mixed-operators [{"allowSamePrecedence":true,"groups":[["==","!=","===","!==",">",">=","<","<="],["&&","||"],["in","instanceof"]]}]",
      "style/no-mixed-spaces-and-tabs",
      "style/no-multi-spaces",
      "style/no-multiple-empty-lines [{"max":1,"maxBOF":0,"maxEOF":0}]",
      "style/no-trailing-spaces",
      "style/no-whitespace-before-property",
      "style/object-curly-spacing ["always"]",
      "style/object-property-newline [{"allowAllPropertiesOnSameLine":true}]",
      "style/operator-linebreak ["before"]",
      "style/padded-blocks [{"blocks":"never","classes":"never","switches":"never"}]",
      "style/padding-line-between-statements [{"blankLine":"always","next":"*","prev":["block","block-like","class","export","import"]},{"blankLine":"never","next":"*","prev":["case"]},{"blankLine":"any","next":["export","import"],"prev":["export","import"]},{"blankLine":"any","next":"*","prev":["do"]}]",
      "style/quote-props ["consistent-as-needed"]",
      "style/quotes ["double",{"allowTemplateLiterals":"never","avoidEscape":true}]",
      "style/rest-spread-spacing ["never"]",
      "style/semi ["always"]",
      "style/semi-spacing [{"after":true,"before":false}]",
      "style/space-before-blocks ["always"]",
      "style/space-before-function-paren [{"anonymous":"always","asyncArrow":"always","named":"never"}]",
      "style/space-in-parens ["never"]",
      "style/space-infix-ops",
      "style/space-unary-ops [{"nonwords":false,"words":true}]",
      "style/spaced-comment ["always",{"markers":["!native","!optimize"]}]",
      "style/template-curly-spacing",
      "style/template-tag-spacing ["never"]",
      "style/type-annotation-spacing [{}]",
      "style/type-generic-spacing",
      "style/type-named-tuple-spacing",
      "style/wrap-iife ["any",{"functionPrototypeMethods":true}]",
      "style/yield-star-spacing [{"after":true,"before":false}]",
    ],
  },
  {
    "name": "isentinel/perfectionist/setup",
    "plugins": [
      "perfectionist",
    ],
  },
  {
    "files": [
      "**/*.{,c,m}[jt]s{,x}",
    ],
    "name": "isentinel/perfectionist",
    "rules": [
      "perfectionist/sort-array-includes",
      "perfectionist/sort-classes (warn) [{"customGroups":[{"elementNamePattern":"constructor","groupName":"custom-constructor"},{"groupName":"private","modifiers":["private"],"newlinesInside":1,"selector":"method","type":"unsorted"},{"groupName":"protected","modifiers":["protected"],"newlinesInside":1,"selector":"method","type":"unsorted"},{"groupName":"public","modifiers":["public"],"newlinesInside":1,"selector":"method","type":"unsorted"}],"fallbackSort":{"order":"asc","type":"natural"},"groups":["private-static-readonly-property","private-readonly-property","private-static-property","private-property","protected-static-readonly-property","protected-readonly-property","protected-static-property","protected-property","public-static-readonly-property","public-readonly-property","public-static-property","public-property","custom-constructor","public","protected","private","unknown"],"newlinesBetween":1,"useExperimentalDependencyDetection":true}]",
      "perfectionist/sort-decorators",
      "perfectionist/sort-enums [{"sortByValue":"always"}]",
      "perfectionist/sort-exports",
      "perfectionist/sort-heritage-clauses [{"customGroups":[],"groups":["unknown"]}]",
      "perfectionist/sort-interfaces [{"customGroups":[{"elementNamePattern":"^id$","groupName":"id"},{"elementNamePattern":"^key$","groupName":"key"},{"elementNamePattern":"^name$","groupName":"name"}],"groups":["id","key","name","unknown"]}]",
      "perfectionist/sort-intersection-types",
      "perfectionist/sort-maps",
      "perfectionist/sort-named-imports",
      "perfectionist/sort-object-types",
      "perfectionist/sort-objects [{"customGroups":[{"elementNamePattern":"^id$","groupName":"id"},{"elementNamePattern":"^key$","groupName":"key"},{"elementNamePattern":"^name$","groupName":"name"}],"groups":["id","key","name","unknown"]}]",
      "perfectionist/sort-sets",
      "perfectionist/sort-switch-case",
      "perfectionist/sort-union-types",
      "perfectionist/sort-variable-declarations",
    ],
    "settings": {
      "perfectionist": {
        "order": "asc",
        "partitionByComment": "^Part:\\s*(.*)$",
        "type": "natural",
      },
    },
  },
  {
    "files": [
      "**/*.{,c,m}jsx",
      "**/*.{,c,m}tsx",
    ],
    "name": "isentinel/perfectionist/jsx",
    "rules": [
      "perfectionist/sort-interfaces [{"customGroups":[{"elementNamePattern":"^id$","groupName":"id"},{"elementNamePattern":"^key$","groupName":"key"},{"elementNamePattern":"^name$","groupName":"name"},{"elementNamePattern":["\\b(on[A-Z][a-zA-Z]*)\\b"],"groupName":"callbacks"},{"elementNamePattern":["^children$","^ref$"],"groupName":"react"}],"groups":["id","key","name","unknown","react","callbacks"]}]",
      "perfectionist/sort-jsx-props [{"customGroups":[{"elementNamePattern":"^(?:key|ref)$","groupName":"reserved"},{"elementNamePattern":"^on.+","groupName":"callback"}],"groups":["reserved","shorthand-prop","unknown","callback"]}]",
      "perfectionist/sort-objects [{"customGroups":[{"elementNamePattern":"^id$","groupName":"id"},{"elementNamePattern":"^key$","groupName":"key"},{"elementNamePattern":"^name$","groupName":"name"},{"elementNamePattern":["\\b(on[A-Z][a-zA-Z]*)\\b"],"groupName":"callbacks"},{"elementNamePattern":["^children$","^ref$"],"groupName":"react"}],"groups":["id","key","name","unknown","react","callbacks"]}]",
    ],
  },
  {
    "name": "isentinel/jsonc/setup",
    "plugins": [
      "jsonc",
    ],
  },
  {
    "files": [
      "**/*.json",
      "**/*.json5",
      "**/*.jsonc",
    ],
    "languageOptions": {
      "parser": "jsonc-eslint-parser",
