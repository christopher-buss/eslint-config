      "jsdoc/no-defaults (warn)",
      "jsdoc/no-multi-asterisks (warn)",
      "jsdoc/no-types (warn)",
      "jsdoc/no-undefined-types",
      "jsdoc/require-asterisk-prefix (warn)",
